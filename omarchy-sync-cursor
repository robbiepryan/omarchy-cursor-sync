    random_btn.bind("<Enter>", lambda e: random_btn.configure(bg=GLASS_INNER, fg=FG))
    random_btn.bind("<Leave>", lambda e: random_btn.configure(bg=GLASS, fg=VIOLET))

    # Cancel button
    cancel_frame = tk.Frame(bottom, bg=GLASS_EDGE, padx=1, pady=1)
    cancel_frame.pack(side=tk.RIGHT, padx=(8, 0))

    cancel_btn = tk.Label(
        cancel_frame, text="  Cancel  ", font=("Helvetica Neue", 9),
        fg=FG_DIM, bg=GLASS, padx=12, pady=5, cursor="hand2",
    )
    cancel_btn.pack()
    cancel_btn.bind("<Button-1>", lambda e: cancel())
    cancel_btn.bind("<Enter>", lambda e: cancel_btn.configure(fg=FG))
    cancel_btn.bind("<Leave>", lambda e: cancel_btn.configure(fg=FG_DIM))

    # Apply button (accent styled)
    apply_frame = tk.Frame(bottom, bg=SUCCESS, padx=1, pady=1)
    apply_frame.pack(side=tk.RIGHT)


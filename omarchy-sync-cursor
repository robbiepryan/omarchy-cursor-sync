def hex_to_rgb(hex_color: str) -> Tuple[int, int, int]:
    """Convert hex color to RGB tuple."""
    hex_color = hex_color.lstrip('#')
    return tuple(int(hex_color[i:i+2], 16) for i in (0, 2, 4))

def rgb_to_hex(r: int, g: int, b: int) -> str:
    """Convert RGB to hex color."""
    return f"#{r:02x}{g:02x}{b:02x}"

def relative_luminance(hex_color: str) -> float:
    """Calculate relative luminance of a color (0-1 scale)."""
    r, g, b = hex_to_rgb(hex_color)
    # Convert to sRGB
    def linearize(c):
        c = c / 255.0
        return c / 12.92 if c <= 0.03928 else ((c + 0.055) / 1.055) ** 2.4
    return 0.2126 * linearize(r) + 0.7152 * linearize(g) + 0.0722 * linearize(b)

def contrast_ratio(color1: str, color2: str) -> float:
    """Calculate contrast ratio between two colors."""
    l1 = relative_luminance(color1)
    l2 = relative_luminance(color2)
    lighter = max(l1, l2)
    darker = min(l1, l2)
    return (lighter + 0.05) / (darker + 0.05)

def darken_color(hex_color: str, factor: float = 0.3) -> str:
    """Darken a color by a factor (0-1)."""
    r, g, b = hex_to_rgb(hex_color)
    r = int(r * (1 - factor))
    g = int(g * (1 - factor))
    b = int(b * (1 - factor))
    return rgb_to_hex(r, g, b)

def lighten_color(hex_color: str, factor: float = 0.3) -> str:
    """Lighten a color by a factor (0-1)."""
    r, g, b = hex_to_rgb(hex_color)
    r = min(255, int(r + (255 - r) * factor))
    g = min(255, int(g + (255 - g) * factor))
    b = min(255, int(b + (255 - b) * factor))
    return rgb_to_hex(r, g, b)

def is_light_color(hex_color: str) -> bool:
    """Check if a color is light (luminance > 0.5)."""
    return relative_luminance(hex_color) > 0.5

def get_saturation(hex_color: str) -> float:
    """Get saturation of a color (0-1 scale)."""
    r, g, b = hex_to_rgb(hex_color)
    max_c = max(r, g, b)
    min_c = min(r, g, b)
    if max_c == 0:
        return 0.0
    return (max_c - min_c) / max_c

def is_vibrant(hex_color: str, min_saturation: float = 0.3) -> bool:
    """Check if a color is vibrant enough to be visually interesting."""
    return get_saturation(hex_color) >= min_saturation

def ensure_contrast(base: str, outline: str, min_ratio: float = 3.0) -> str:
    """Adjust outline color to ensure minimum contrast with base."""
    if contrast_ratio(base, outline) >= min_ratio:
        return outline

    # If base is light, make outline darker; otherwise lighter
    if is_light_color(base):
        adjusted = outline
        for _ in range(10):
            adjusted = darken_color(adjusted, 0.15)
            if contrast_ratio(base, adjusted) >= min_ratio:
                return adjusted
        return "#000000"
    else:
        adjusted = outline
        for _ in range(10):
            adjusted = lighten_color(adjusted, 0.15)
            if contrast_ratio(base, adjusted) >= min_ratio:
                return adjusted
        return "#ffffff"

def validate_hex_color(color: str) -> str:
    """Validate and normalize hex color to #RRGGBB format.

    Args:
        color: Hex color string (#RGB or #RRGGBB)

    Returns:
        Normalized #RRGGBB format

    Raises:
        ValueError: If color format is invalid
    """
    color = color.strip()

    # Match #RGB or #RRGGBB
    match = re.match(r'^#?([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$', color)
    if not match:
        raise ValueError(f"Invalid hex color: '{color}'. Use format #RGB or #RRGGBB (e.g., #ff00ff)")

    hex_part = match.group(1)

    # Expand #RGB to #RRGGBB
    if len(hex_part) == 3:
        hex_part = ''.join(c * 2 for c in hex_part)

    return f"#{hex_part.lower()}"

def generate_random_vibrant_color() -> str:
    """Generate a random vibrant, saturated color suitable for a cursor.

    Uses HSV color space to ensure the color is always visually striking:
    - Random hue (0-360)
    - High saturation (0.7-1.0)
    - Medium-high value (0.6-0.9)

    Returns:
        Hex color string in #RRGGBB format
    """
    hue = random.random()  # 0-1
    saturation = 0.7 + random.random() * 0.3  # 0.7-1.0
    value = 0.6 + random.random() * 0.3  # 0.6-0.9

    r, g, b = colorsys.hsv_to_rgb(hue, saturation, value)
    return rgb_to_hex(int(r * 255), int(g * 255), int(b * 255))


def setup_logging(config: Config) -> logging.Logger:
    """Set up logging to file and console."""
    logger = logging.getLogger("omarchy-sync-cursor")
    logger.setLevel(logging.INFO)
    
    # Console handler
    console = logging.StreamHandler()
    console.setLevel(logging.INFO)
    console.setFormatter(logging.Formatter("%(message)s"))
    logger.addHandler(console)
    
    # File handler
    log_file = config.cache_dir / "sync.log"
    config.cache_dir.mkdir(parents=True, exist_ok=True)
    file_handler = logging.FileHandler(log_file)
    file_handler.setLevel(logging.DEBUG)
    file_handler.setFormatter(logging.Formatter("%(asctime)s - %(levelname)s - %(message)s"))
    logger.addHandler(file_handler)
    
    return logger

def get_current_theme() -> Optional[str]:
    """Try to determine the currently active Omarchy theme."""
    # Check for a theme indicator file
    active_file = Path.home() / ".config" / "omarchy" / "active-theme"
    if active_file.exists():
        return active_file.read_text().strip()
    
    # Try to read from a symlink
    current_link = Path.home() / ".config" / "omarchy" / "current-theme"
    if current_link.is_symlink():
        return current_link.resolve().name
    
    return None

def main():
    parser = argparse.ArgumentParser(
        description="Sync Bibata cursor colors with Omarchy theme"
    )
    parser.add_argument(
        "theme",
        nargs="?",
        help="Theme name to sync cursor colors with"
    )
    parser.add_argument(
        "--current",
        action="store_true",
        help="Use currently active theme"
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Force rebuild even if cached"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without making changes"
    )
    parser.add_argument(
        "--base-color",
        metavar="HEX",
        help="Override cursor fill color (e.g., #ff00ff)"
    )
    parser.add_argument(
        "--outline-color",
        metavar="HEX",
        help="Override cursor outline color (e.g., #000000)"
    )
    parser.add_argument(
        "--watch-color",
        metavar="HEX",
        help="Override loading animation background color"
    )
    parser.add_argument(
        "--color-only",
        action="store_true",
        help="Use explicit colors without requiring a theme"
    )
    parser.add_argument(
        "--random",
        action="store_true",
        help="Generate a random vibrant cursor color"
    )
    parser.add_argument(
        "--picker",
        action="store_true",
        help="Open GUI color picker to select cursor color"
    )

    args = parser.parse_args()

    # Load configuration
    config = load_config()
    logger = setup_logging(config)

    # Validate color arguments if provided
    cli_base_color = None
    cli_outline_color = None
    cli_watch_color = None

    try:
        if args.base_color:
            cli_base_color = validate_hex_color(args.base_color)
        if args.outline_color:
            cli_outline_color = validate_hex_color(args.outline_color)
        if args.watch_color:
            cli_watch_color = validate_hex_color(args.watch_color)
    except ValueError as e:
        logger.error(str(e))
        sys.exit(1)

    # Handle --picker mode: open GUI color picker
    if args.picker:
        try:
            initial = cli_base_color or "#ff00ff"
            picked_color = open_color_picker(initial)
            if picked_color:
                cli_base_color = picked_color
                logger.info(f"Selected color: {picked_color}")
            else:
                logger.info("Color picker cancelled")
                sys.exit(0)
        except RuntimeError as e:
            logger.error(str(e))
            sys.exit(1)

    # Handle --color-only or --random or --picker mode (no theme required)
    color_only_mode = args.color_only or args.random or args.picker

    if color_only_mode:
        # In color-only mode, we need at least --base-color, --random, or --picker
        if not args.random and not args.picker and not cli_base_color:
            logger.error("--color-only requires --base-color, --random, or --picker")
            sys.exit(1)

        # Generate random color if requested
        if args.random:
            random_color = generate_random_vibrant_color()
            logger.info(f"Generated random color: {random_color}")
            if not cli_base_color:
                cli_base_color = random_color

        # Create a custom theme name from colors
        color_hash = hashlib.sha256(cli_base_color.encode()).hexdigest()[:8]
        theme_name = f"custom-{color_hash}"
        theme_path = None  # No theme path needed

        # Default colors for outline and watch if not specified
        base_color = cli_base_color.upper()
        outline_color = cli_outline_color.upper() if cli_outline_color else ensure_contrast(base_color, "#1e1e2e").upper()
        watch_color = cli_watch_color.upper() if cli_watch_color else darken_color(outline_color, 0.2).upper()

        cursor_theme_name = get_cursor_theme_name(theme_name)
        logger.info(f"Building custom cursor with colors:")
        logger.info(f"  Base:    {base_color}")
        logger.info(f"  Outline: {outline_color}")
        logger.info(f"  Watch:   {watch_color}")

    else:
        # Standard theme-based mode
        # Determine theme name
        if args.current:
            theme_name = get_current_theme()
            if not theme_name:
                logger.error("Could not determine current theme. Please specify theme name.")
                sys.exit(1)
        elif args.theme:
            theme_name = args.theme
        else:
            parser.print_help()
            sys.exit(1)

        logger.info(f"Syncing cursor for theme: {theme_name}")

        # Resolve theme path
        theme_path = config.themes_dir / theme_name
        if not theme_path.exists():
            logger.error(f"Theme not found: {theme_path}")
            sys.exit(1)

        cursor_theme_name = get_cursor_theme_name(theme_name)

        # Extract colors from theme
        logger.info("Extracting theme colors...")
        colors = extract_theme_colors(theme_path, config.color_source)

        # Compute cursor colors from theme
        base_color, outline_color, watch_color = compute_cursor_colors(colors, config)

        # Apply overrides: CLI args > config file > auto-computed
        # Config file overrides
        if config.override_base_color:
            try:
                base_color = validate_hex_color(config.override_base_color).upper()
            except ValueError:
                logger.warning(f"Invalid base_color in config: {config.override_base_color}, using auto")
        if config.override_outline_color:
            try:
                outline_color = validate_hex_color(config.override_outline_color).upper()
            except ValueError:
                logger.warning(f"Invalid outline_color in config: {config.override_outline_color}, using auto")
        if config.override_watch_color:
            try:
                watch_color = validate_hex_color(config.override_watch_color).upper()
            except ValueError:
                logger.warning(f"Invalid watch_color in config: {config.override_watch_color}, using auto")

        # CLI overrides (highest priority)
        if cli_base_color:
            base_color = cli_base_color.upper()
        if cli_outline_color:
            outline_color = cli_outline_color.upper()
        if cli_watch_color:
            watch_color = cli_watch_color.upper()

        # Handle --random with a theme (overrides base color only)
        if args.random:
            base_color = generate_random_vibrant_color().upper()
            logger.info(f"Generated random base color: {base_color}")

        logger.info(f"Final cursor colors:")
        logger.info(f"  Base:    {base_color}")
        logger.info(f"  Outline: {outline_color}")
        logger.info(f"  Watch:   {watch_color}")

    if args.dry_run:
        logger.info("Dry run - no changes made")
        sys.exit(0)

    try:
        # First: check color-based cache (works for any color combo)
        color_hash = get_color_hash(base_color, outline_color, watch_color)
        cached_theme = check_color_cache(config, color_hash) if not args.force else None

        if cached_theme:
            logger.info(f"Using color-cached theme: {cached_theme} (instant)")
            cursor_theme_name = cached_theme
        else:
            # Check theme-based cache (only for theme-based builds with no CLI overrides)
            use_theme_cache = (
                theme_path is not None
                and not args.force
                and not cli_base_color
                and not cli_outline_color
                and not cli_watch_color
                and not args.random
            )

            if use_theme_cache:
                theme_hash = get_theme_hash(theme_path, config.color_source)
                if check_cache(config, theme_name, theme_hash):
                    logger.info("Using cached cursor theme (colors unchanged)")
                else:
                    # Build cursor theme
                    logger.info("Building cursor theme...")
                    theme_src = build_cursor_theme(
                        config, theme_name,
                        base_color, outline_color, watch_color,
                        logger
                    )

                    # Install
                    install_cursor_theme(config, theme_src, cursor_theme_name, logger)

                    # Update both caches
                    update_cache_meta(config, theme_name, theme_hash, cursor_theme_name)
                    update_color_cache(config, color_hash, cursor_theme_name)
            else:
                # Build for custom colors or forced rebuild
                logger.info("Building cursor theme...")
                theme_src = build_cursor_theme(
                    config, theme_name,
                    base_color, outline_color, watch_color,
                    logger
                )

                # Install
                install_cursor_theme(config, theme_src, cursor_theme_name, logger)

                # Update color cache
                update_color_cache(config, color_hash, cursor_theme_name)
        
        # Apply cursor
        apply_cursor_hyprland(cursor_theme_name, config.cursor_size, logger)
        write_cursor_config(config, cursor_theme_name, logger)
        apply_cursor_gtk(cursor_theme_name, config.cursor_size, logger)
        
        logger.info(f"✓ Cursor synced successfully: {cursor_theme_name}")
        
    except FileNotFoundError as e:
        logger.error(f"File not found: {e}")
        sys.exit(1)
    except RuntimeError as e:
        logger.error(f"Build failed: {e}")
        sys.exit(1)
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)

if __name__ == "__main__":
    main()

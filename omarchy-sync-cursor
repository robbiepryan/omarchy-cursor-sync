    SV_W, SV_H = 260, 130

    def draw_sv_pad():
        sv_canvas.delete("all")

        # Glass panel effect
        draw_glass_panel(sv_canvas, 0, 0, SV_W, SV_H)

        # Color gradient - drawn in blocks for performance
        step = 4
        pad = 6  # Inner padding
        for x in range(pad, SV_W - pad, step):
            for y in range(pad, SV_H - pad, step):
                s_val = (x - pad) / (SV_W - pad * 2)
                v_val = 1.0 - ((y - pad) / (SV_H - pad * 2))
                c = hsv_to_hex_local(current_hsv[0], s_val, v_val)
                sv_canvas.create_rectangle(x, y, x + step, y + step, fill=c, outline="")

        # Selection crosshair with glow
        ix = int(current_hsv[1] * (SV_W - pad * 2)) + pad
        iy = int((1.0 - current_hsv[2]) * (SV_H - pad * 2)) + pad
        ix = max(pad + 4, min(SV_W - pad - 4, ix))
        iy = max(pad + 4, min(SV_H - pad - 4, iy))

        # Outer glow ring
        sv_canvas.create_oval(ix - 10, iy - 10, ix + 10, iy + 10,
                             outline=ACCENT_DIM, width=2, fill="")
        # Inner ring
        ring_color = "#ffffff" if current_hsv[2] < 0.6 else "#000000"
        sv_canvas.create_oval(ix - 6, iy - 6, ix + 6, iy + 6,
                             outline=ring_color, width=2, fill="")
        # Center dot
        sv_canvas.create_oval(ix - 2, iy - 2, ix + 2, iy + 2,
                             fill=ACCENT, outline="")

    def on_sv_event(event):
        pad = 6
        s = max(0.0, min(1.0, (event.x - pad) / (SV_W - pad * 2)))
        v = max(0.0, min(1.0, 1.0 - (event.y - pad) / (SV_H - pad * 2)))
        current_hsv[1] = s
        current_hsv[2] = v
        sync_all()


def build_cursor_theme(
    config: Config,
    theme_name: str,
    base_color: str,
    outline_color: str,
    watch_color: str,
    logger: logging.Logger,
    preset: Optional[TransparencyPreset] = None
) -> Path:
    """Build Bibata cursor theme with custom colors and optional transparency."""

    cursor_theme_name = get_cursor_theme_name(theme_name, preset.name if preset else None)
    bitmap_dir = config.cache_dir / theme_name / "bitmaps"

    # Ensure clean bitmap directory
    if bitmap_dir.exists():
        shutil.rmtree(bitmap_dir)
    bitmap_dir.mkdir(parents=True, exist_ok=True)

    original_svg_dir = config.bibata_source_dir / "svg" / config.cursor_style

    if not original_svg_dir.exists():
        raise FileNotFoundError(f"SVG directory not found: {original_svg_dir}")

    # Apply transparency if preset provided (returns temp dir or original)
    svg_dir = apply_transparency(original_svg_dir, preset) if preset else original_svg_dir
    temp_svg_dir = svg_dir if svg_dir != original_svg_dir else None

    # Step 1: Run cbmp to render SVGs to PNGs
    logger.info(f"Rendering cursor bitmaps with colors: base={base_color}, outline={outline_color}, watch={watch_color}")
    if preset and preset.name != "classic":
        logger.info(f"  Transparency preset: {preset.name} (base={preset.base_opacity}, outline={preset.outline_opacity})")
    logger.info("  [1/2] Rendering SVGs to bitmaps (this takes ~10-15s)...")

    cbmp_cmd = [
        "npx", "cbmp",
        "-d", str(svg_dir),
        "-o", str(bitmap_dir),
        "-bc", base_color,
        "-oc", outline_color,
        "-wc", watch_color
    ]

    # Run with real-time output for progress indication
    process = subprocess.Popen(
        cbmp_cmd,
        cwd=config.bibata_source_dir,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True
    )

    # Stream output to show progress
    output_lines = []
    for line in process.stdout:
        output_lines.append(line)
        # Show dots for progress without flooding logs
        if len(output_lines) % 20 == 0:
            print(".", end="", flush=True)
    print()  # newline after dots

    process.wait()

    # Clean up temp SVG directory if we created one
    if temp_svg_dir and temp_svg_dir.exists():
        shutil.rmtree(temp_svg_dir)

    if process.returncode != 0:
        logger.error(f"cbmp failed: {''.join(output_lines)}")
        raise RuntimeError("cbmp failed")

    logger.info("  Bitmap rendering complete")
    
    # Step 2: Run ctgen to build cursor theme
    logger.info(f"  [2/2] Building cursor package: {cursor_theme_name} (~5s)...")

    # Find build.toml - check configs directory first
    build_toml = config.bibata_source_dir / "configs" / "normal" / "x.build.toml"
    if not build_toml.exists():
        build_toml = config.bibata_source_dir / "build.toml"

    if not build_toml.exists():
        raise FileNotFoundError(f"build.toml not found in {config.bibata_source_dir}")

    ctgen_path = config.venv_path / "bin" / "ctgen"

    ctgen_cmd = [
        str(ctgen_path),
        str(build_toml),
        "-d", str(bitmap_dir),
        "-n", cursor_theme_name,
        "-c", f"Omarchy {theme_name} Bibata cursor theme"
    ]

    process = subprocess.Popen(
        ctgen_cmd,
        cwd=config.bibata_source_dir,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True
    )

    output_lines = []
    for line in process.stdout:
        output_lines.append(line)
        if len(output_lines) % 10 == 0:
            print(".", end="", flush=True)
    print()

    process.wait()

    output_text = ''.join(output_lines)
    if process.returncode != 0 or '[Fail]' in output_text:
        logger.error(f"ctgen failed: {output_text}")
        raise RuntimeError("ctgen failed")

    logger.info("  Cursor theme build complete")
    
    # Find built theme
    theme_src = config.bibata_source_dir / "themes" / cursor_theme_name
    if not theme_src.exists():
        # Check in current working directory
        theme_src = Path.cwd() / "themes" / cursor_theme_name
    
    if not theme_src.exists():
        raise FileNotFoundError(f"Built theme not found at {theme_src}")
    
    return theme_src

def install_cursor_theme(config: Config, theme_src: Path, cursor_theme_name: str, logger: logging.Logger):
    """Install cursor theme to icons directory."""
    theme_dest = config.icons_dir / cursor_theme_name
    
    logger.info(f"Installing cursor theme to {theme_dest}")
    
    # Remove existing
    if theme_dest.exists():
        shutil.rmtree(theme_dest)
    
    # Ensure icons directory exists
    config.icons_dir.mkdir(parents=True, exist_ok=True)
    
    # Copy theme
    shutil.copytree(theme_src, theme_dest)
    
    logger.info("Cursor theme installed")


# Caching
# ============================================================================

def get_theme_hash(theme_path: Path, color_source: str) -> str:
    """Generate a hash of the color file for cache validation."""
    color_file = theme_path / color_source
    if color_file.exists():
        content = color_file.read_bytes()
        return hashlib.sha256(content).hexdigest()[:16]
    return ""

def get_cursor_theme_name(theme_name: str) -> str:
    """Generate a safe cursor theme name."""
    # Make filesystem-safe
    safe_name = "".join(c if c.isalnum() or c in "-_" else "-" for c in theme_name)
    return f"Bibata-Omarchy-{safe_name}"

def get_color_hash(base: str, outline: str, watch: str) -> str:
    """Generate a hash from cursor colors for caching."""
    color_str = f"{base.lower()}{outline.lower()}{watch.lower()}"
    return hashlib.sha256(color_str.encode()).hexdigest()[:12]

def check_color_cache(config: Config, color_hash: str) -> Optional[str]:
    """Check if a cursor theme with these exact colors exists."""
    cache_meta = config.cache_dir / "color-cache.json"
    if not cache_meta.exists():
        return None
    try:
        with open(cache_meta) as f:
            cache = json.load(f)
        theme_name = cache.get(color_hash)
        if theme_name and (config.icons_dir / theme_name).exists():
            return theme_name
    except Exception:
        pass
    return None

def update_color_cache(config: Config, color_hash: str, cursor_theme_name: str):
    """Store color->theme mapping for instant reuse."""
    cache_meta = config.cache_dir / "color-cache.json"
    config.cache_dir.mkdir(parents=True, exist_ok=True)
    try:
        cache = {}
        if cache_meta.exists():
            with open(cache_meta) as f:
                cache = json.load(f)
        cache[color_hash] = cursor_theme_name
        # Keep only last 20 entries to avoid bloat
        if len(cache) > 20:
            cache = dict(list(cache.items())[-20:])
        with open(cache_meta, "w") as f:
            json.dump(cache, f, indent=2)
    except Exception:
        pass

def check_cache(config: Config, theme_name: str, theme_hash: str) -> bool:
    """Check if a valid cached cursor theme exists."""
    cursor_theme_name = get_cursor_theme_name(theme_name)
    theme_dest = config.icons_dir / cursor_theme_name
    cache_meta = config.cache_dir / theme_name / "meta.json"
    
    if not theme_dest.exists() or not cache_meta.exists():
        return False
    
    try:
        with open(cache_meta) as f:
            meta = json.load(f)
        return meta.get("hash") == theme_hash
    except Exception:
        return False

def update_cache_meta(config: Config, theme_name: str, theme_hash: str, cursor_theme_name: str):
    """Update cache metadata after successful build."""
    cache_theme_dir = config.cache_dir / theme_name
    cache_theme_dir.mkdir(parents=True, exist_ok=True)
    
    meta = {
        "hash": theme_hash,
        "cursor_theme_name": cursor_theme_name,
    }
    
    with open(cache_theme_dir / "meta.json", "w") as f:
        json.dump(meta, f, indent=2)


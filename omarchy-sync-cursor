# Theme Color Parsing
# ============================================================================

def parse_alacritty_toml_simple(content: str) -> Dict:
    """Simple TOML parser for alacritty.toml (handles nested sections)."""
    result = {}
    current_section = []
    
    for line in content.splitlines():
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        
        # Section header
        if line.startswith('[') and line.endswith(']'):
            section = line[1:-1]
            # Handle [[array]] notation
            if section.startswith('[') and section.endswith(']'):
                continue  # Skip array sections for now
            current_section = section.split('.')
            # Ensure nested structure exists
            d = result
            for key in current_section:
                if key not in d:
                    d[key] = {}
                d = d[key]
        elif '=' in line:
            # Key-value pair
            key, value = line.split('=', 1)
            key = key.strip()
            value = value.strip().strip('"\'')
            
            # Navigate to current section and set value
            d = result
            for section_key in current_section:
                d = d.get(section_key, {})
            if isinstance(d, dict):
                d[key] = value
    
    return result

def extract_theme_colors(theme_path: Path, color_source: str) -> Dict[str, str]:
    """Extract colors from theme's color source file."""
    color_file = theme_path / color_source
    if not color_file.exists():
        raise FileNotFoundError(f"Color file not found: {color_file}")
    
    content = color_file.read_text()
    
    if HAS_TOML:
        data = toml.loads(content)
    else:
        data = parse_alacritty_toml_simple(content)
    
    colors = {}
    
    # Extract primary colors
    primary = data.get("colors", {}).get("primary", {})
    colors["background"] = primary.get("background", "#1e1e2e")
    colors["foreground"] = primary.get("foreground", "#cdd6f4")
    
    # Extract cursor colors if available
    cursor = data.get("colors", {}).get("cursor", {})
    colors["cursor"] = cursor.get("cursor", colors["foreground"])
    colors["cursor_text"] = cursor.get("text", colors["background"])
    
    # Extract selection colors
    selection = data.get("colors", {}).get("selection", {})
    colors["selection_bg"] = selection.get("background", colors["foreground"])
    
    # Extract normal palette colors
    normal = data.get("colors", {}).get("normal", {})
    colors["black"] = normal.get("black", "#45475a")
    colors["red"] = normal.get("red", "#f38ba8")
    colors["green"] = normal.get("green", "#a6e3a1")
    colors["yellow"] = normal.get("yellow", "#f9e2af")
    colors["blue"] = normal.get("blue", "#89b4fa")
    colors["magenta"] = normal.get("magenta", "#f5c2e7")
    colors["cyan"] = normal.get("cyan", "#94e2d5")
    colors["white"] = normal.get("white", "#bac2de")
    
    # Extract bright palette (useful for accents)
    bright = data.get("colors", {}).get("bright", {})
    colors["bright_magenta"] = bright.get("magenta", colors["magenta"])
    colors["bright_cyan"] = bright.get("cyan", colors["cyan"])
    colors["bright_blue"] = bright.get("blue", colors["blue"])
    
    return colors


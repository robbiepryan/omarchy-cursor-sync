def setup_logging(config: Config) -> logging.Logger:
    """Set up logging to file and console."""
    logger = logging.getLogger("omarchy-sync-cursor")
    logger.setLevel(logging.INFO)
    
    # Console handler
    console = logging.StreamHandler()
    console.setLevel(logging.INFO)
    console.setFormatter(logging.Formatter("%(message)s"))
    logger.addHandler(console)
    
    # File handler
    log_file = config.cache_dir / "sync.log"
    config.cache_dir.mkdir(parents=True, exist_ok=True)
    file_handler = logging.FileHandler(log_file)
    file_handler.setLevel(logging.DEBUG)
    file_handler.setFormatter(logging.Formatter("%(asctime)s - %(levelname)s - %(message)s"))
    logger.addHandler(file_handler)
    
    return logger

def get_current_theme() -> Optional[str]:
    """Try to determine the currently active Omarchy theme."""
    # Check for a theme indicator file
    active_file = Path.home() / ".config" / "omarchy" / "active-theme"
    if active_file.exists():
        return active_file.read_text().strip()
    
    # Try to read from a symlink
    current_link = Path.home() / ".config" / "omarchy" / "current-theme"
    if current_link.is_symlink():
        return current_link.resolve().name
    
    return None


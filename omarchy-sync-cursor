    def add_current_to_presets():
        """Add current color to presets if not already present."""
        color = current_color().lower()
        if color not in [c.lower() for c in user_presets]:
            user_presets.insert(0, color)
            if len(user_presets) > 24:  # Max presets
                user_presets.pop()
            save_presets(user_presets)
            rebuild_preset_grid()

    def remove_preset(color):
        """Remove a preset color."""
        color_lower = color.lower()
        for i, c in enumerate(user_presets):
            if c.lower() == color_lower:
                user_presets.pop(i)
                save_presets(user_presets)
                rebuild_preset_grid()
                break

    def rebuild_preset_grid():
        """Rebuild the preset swatch grid."""
        # Clear existing widgets
        for w in preset_widgets:
            try:
                w.destroy()
            except tk.TclError:
                pass
        preset_widgets.clear()

        swatch_size = 28
        per_row = 8

        for i, pcolor in enumerate(user_presets[:24]):
            row_idx = i // per_row
            col_idx = i % per_row

            swatch = tk.Canvas(
                preset_grid, width=swatch_size, height=swatch_size,
                bg=GLASS, highlightthickness=0, bd=0, cursor="hand2",
            )
            swatch.grid(row=row_idx, column=col_idx, padx=3, pady=3)
            preset_widgets.append(swatch)

            # Draw the swatch with glass effect
            def draw_swatch(canvas, color, hover=False, delete_mode=False):
                canvas.delete("all")
                # Background
                canvas.create_rectangle(0, 0, swatch_size, swatch_size,
                                       fill=color, outline="")
                # Top highlight
                canvas.create_line(1, 1, swatch_size-1, 1,
                                  fill=lighten_color(color, 0.25))
                # Border
                border_color = FG if hover else GLASS_EDGE
                canvas.create_rectangle(0, 0, swatch_size-1, swatch_size-1,
                                       fill="", outline=border_color, width=1 if not hover else 2)

                # Delete mode: show X
                if delete_mode:
                    canvas.create_line(6, 6, swatch_size-6, swatch_size-6, fill=FG, width=2)
                    canvas.create_line(swatch_size-6, 6, 6, swatch_size-6, fill=FG, width=2)

            draw_swatch(swatch, pcolor)

            # Bind events
            def make_click(c):
                return lambda e: set_color_from_hex(c)

            def make_enter(canvas, c):
                return lambda e: draw_swatch(canvas, c, hover=True)

            def make_leave(canvas, c):
                return lambda e: draw_swatch(canvas, c, hover=False)

            def make_right_click(canvas, c):
                def handler(e):
                    draw_swatch(canvas, c, hover=True, delete_mode=True)
                    canvas.after(150, lambda: remove_preset(c))
                return handler

            swatch.bind("<Button-1>", make_click(pcolor))
            swatch.bind("<Button-3>", make_right_click(swatch, pcolor))
            swatch.bind("<Enter>", make_enter(swatch, pcolor))
            swatch.bind("<Leave>", make_leave(swatch, pcolor))


def apply_cursor_hyprland(cursor_theme_name: str, size: int, logger: logging.Logger):
    """Apply cursor theme in Hyprland."""
    logger.info(f"Applying cursor in Hyprland: {cursor_theme_name} (size {size})")
    
    # Runtime apply
    result = subprocess.run(
        ["hyprctl", "setcursor", cursor_theme_name, str(size)],
        capture_output=True,
        text=True
    )
    
    if result.returncode != 0:
        logger.warning(f"hyprctl setcursor failed (may not be running): {result.stderr}")

def write_cursor_config(config: Config, cursor_theme_name: str, logger: logging.Logger):
    """Write cursor configuration for persistence."""
    logger.info(f"Writing cursor config to {config.cursor_conf}")
    
    config.cursor_conf.parent.mkdir(parents=True, exist_ok=True)
    
    content = f"""# Auto-generated by omarchy-sync-cursor
# Cursor theme configuration

env = HYPRCURSOR_THEME,{cursor_theme_name}
env = HYPRCURSOR_SIZE,{config.cursor_size}
env = XCURSOR_THEME,{cursor_theme_name}
env = XCURSOR_SIZE,{config.cursor_size}
"""
    
    config.cursor_conf.write_text(content)

def apply_cursor_gtk(cursor_theme_name: str, size: int, logger: logging.Logger):
    """Apply cursor theme for GTK applications."""
    logger.info(f"Applying cursor for GTK: {cursor_theme_name}")
    
    # Try gsettings
    try:
        subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.interface", "cursor-theme", cursor_theme_name],
            capture_output=True,
            check=True
        )
        subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.interface", "cursor-size", str(size)],
            capture_output=True,
            check=True
        )
    except Exception as e:
        logger.warning(f"gsettings failed (may not be available): {e}")
        
        # Fallback: Write GTK settings files
        write_gtk_fallback(cursor_theme_name, size, logger)

def write_gtk_fallback(cursor_theme_name: str, size: int, logger: logging.Logger):
    """Write GTK cursor settings to config files."""
    # GTK 2
    gtk2_rc = Path.home() / ".gtkrc-2.0"
    try:
        existing = gtk2_rc.read_text() if gtk2_rc.exists() else ""
        # Remove existing cursor lines
        lines = [l for l in existing.splitlines() if not l.startswith("gtk-cursor-theme")]
        lines.extend([
            f'gtk-cursor-theme-name="{cursor_theme_name}"',
            f'gtk-cursor-theme-size={size}'
        ])
        gtk2_rc.write_text("\n".join(lines) + "\n")
    except Exception as e:
        logger.warning(f"Failed to write GTK2 config: {e}")
    
    # GTK 3
    gtk3_dir = Path.home() / ".config" / "gtk-3.0"
    gtk3_settings = gtk3_dir / "settings.ini"
    try:
        gtk3_dir.mkdir(parents=True, exist_ok=True)
        existing = gtk3_settings.read_text() if gtk3_settings.exists() else "[Settings]\n"
        
        # Simple append/update - a proper INI parser would be better
        if "gtk-cursor-theme-name" not in existing:
            existing += f"gtk-cursor-theme-name={cursor_theme_name}\n"
        if "gtk-cursor-theme-size" not in existing:
            existing += f"gtk-cursor-theme-size={size}\n"
        
        gtk3_settings.write_text(existing)
    except Exception as e:
        logger.warning(f"Failed to write GTK3 config: {e}")


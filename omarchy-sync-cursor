# Aesthetic Color Selection
# ============================================================================

def compute_cursor_colors(colors: Dict[str, str], config: Config) -> Tuple[str, str, str]:
    """
    Compute aesthetically pleasing cursor colors from theme palette.
    
    Design principles:
    1. Base color should be vibrant and visible - use accent/cursor color
    2. Outline should provide strong contrast for visibility
    3. Watch background should be subtle but harmonious
    """
    background = colors.get("background", "#1e1e2e")
    foreground = colors.get("foreground", "#cdd6f4")
    
    # === BASE COLOR ===
    # Priority: cursor color (if distinct) > magenta > cyan > blue
    # We want something that "pops" against both light and dark backgrounds
    
    base_source = config.base_color_source
    base_fallback = config.base_color_fallback
    
    # Try primary source
    if base_source == "cursor":
        base_color = colors.get("cursor", "")
        # Only use cursor color if it's distinct from foreground
        if not base_color or base_color == foreground:
            base_color = ""
    elif base_source in colors:
        base_color = colors[base_source]
    else:
        base_color = ""
    
    # Fallback to accent colors if primary source is empty/unsuitable
    if not base_color:
        # Try fallback, then other accent colors - prefer vibrant colors
        for color_key in [base_fallback, "magenta", "bright_magenta", "cyan", "bright_cyan", "blue", "red", "green", "yellow"]:
            candidate = colors.get(color_key, "")
            if candidate and contrast_ratio(candidate, background) >= 2.5 and is_vibrant(candidate, 0.25):
                base_color = candidate
                break
        
        # If no vibrant color found (monochrome theme), use foreground with good contrast
        if not base_color:
            base_color = colors.get("foreground", "#ffffff")
    
    # === OUTLINE COLOR ===
    # Should contrast well with both base color AND provide cursor visibility
    
    outline_source = config.outline_color_source
    
    if outline_source == "auto_contrast":
        # Auto-select based on base color luminance
        if is_light_color(base_color):
            outline_color = darken_color(background, 0.2) if not is_light_color(background) else "#000000"
        else:
            outline_color = lighten_color(background, 0.2) if is_light_color(background) else "#ffffff"
    elif outline_source == "background":
        outline_color = background
    elif outline_source in colors:
        outline_color = colors[outline_source]
    else:
        outline_color = background
    
    # Ensure minimum contrast
    outline_color = ensure_contrast(base_color, outline_color, min_ratio=3.5)
    
    # === WATCH BACKGROUND COLOR ===
    # For loading animations - should be darker/more subtle
    
    watch_source = config.watch_color_source
    
    if watch_source == "auto_darken":
        # Create a darkened version of background
        watch_color = darken_color(background, 0.3)
    elif watch_source == "selection_background":
        watch_color = colors.get("selection_bg", background)
        # Make it a bit darker for better animation visibility
        if relative_luminance(watch_color) > 0.3:
            watch_color = darken_color(watch_color, 0.4)
    elif watch_source == "background":
        watch_color = darken_color(background, 0.2)
    elif watch_source in colors:
        watch_color = colors[watch_source]
    else:
        watch_color = darken_color(background, 0.2)
    
    # Ensure watch color is darker for better loading animation contrast
    if relative_luminance(watch_color) > 0.4:
        watch_color = darken_color(watch_color, 0.5)
    
    return base_color.upper(), outline_color.upper(), watch_color.upper()


def analyze_theme_properties(colors: Dict[str, str]) -> Dict:
    """Detect theme properties to inform transparency selection."""
    background = colors.get("background", "#1e1e2e")
    foreground = colors.get("foreground", "#cdd6f4")

    luminance_bg = relative_luminance(background)
    luminance_fg = relative_luminance(foreground)
    saturation_bg = get_saturation(background)
    contrast = contrast_ratio(foreground, background)

    return {
        "is_light_theme": luminance_bg > 0.6,
        "bg_luminance": luminance_bg,
        "fg_luminance": luminance_fg,
        "bg_saturation": saturation_bg,
        "contrast_ratio": contrast,
        "is_high_contrast": contrast > 7.0,
        "is_vibrant": saturation_bg > 0.3,
    }

TRANSPARENCY_PRESETS = {
    "glass": TransparencyPreset("glass", 0.75, 0.85, 0.70),
    "shadow": TransparencyPreset("shadow", 0.95, 1.0, 0.90),
    "neon": TransparencyPreset("neon", 0.60, 0.75, 0.55),
    "outline": TransparencyPreset("outline", 0.0, 1.0, 0.3),
    "classic": TransparencyPreset("classic", 1.0, 1.0, 1.0),
}

def select_transparency_preset(theme_props: Dict, override: Optional[str] = None) -> TransparencyPreset:
    """Select transparency preset based on theme properties.

    Args:
        theme_props: Dictionary from analyze_theme_properties()
        override: Manual override ("glass", "shadow", "neon", "classic", or None/"auto")

    Returns:
        TransparencyPreset dataclass with opacity values
    """
    # Explicit user choice always wins (not "auto", not None)
    if override and override != "auto" and override in TRANSPARENCY_PRESETS:
        return TRANSPARENCY_PRESETS[override]

    # Auto-selection: light themes default to classic
    if theme_props.get("is_light_theme"):
        preset_name = "classic"
    # Dark + vibrant background (saturation > 0.5) -> NEON
    elif theme_props.get("bg_saturation", 0) > 0.5:
        preset_name = "neon"
    # Dark themes -> GLASS
    else:
        preset_name = "glass"

    return TRANSPARENCY_PRESETS[preset_name]

def apply_transparency(svg_dir: Path, preset: TransparencyPreset) -> Path:
    """Apply transparency to SVG files by modifying opacity attributes.

    Creates a temporary copy of the SVG directory with opacity modifications.
    If preset is fully opaque (all 1.0), returns original directory.
    Caller must clean up the returned temp directory when done.

    Args:
        svg_dir: Path to SVG source directory
        preset: TransparencyPreset with opacity values

    Returns:
        Path to SVG directory (original if opaque, or modified temp copy)
    """
    import xml.etree.ElementTree as ET

    # If fully opaque, skip modification
    if preset.base_opacity >= 1.0 and preset.outline_opacity >= 1.0 and preset.watch_opacity >= 1.0:
        return svg_dir

    temp_dir = Path(tempfile.mkdtemp(prefix="svg-transparency-"))

    try:
        # Copy entire SVG directory resolving symlinks. Bibata uses symlinks
        # extensively (files and subdirectories like left_ptr_watch/, wait/),
        # and Path.glob("**/*") on Python 3.13+ does not follow symlinked
        # directories. copytree with symlinks=False resolves all symlinks.
        shutil.copytree(svg_dir, temp_dir, symlinks=False, dirs_exist_ok=True)

        # Modify SVGs in-place in the copy (all files are real, not symlinks)
        for svg_file in temp_dir.rglob("*.svg"):
            try:
                tree = ET.parse(svg_file)
                root = tree.getroot()

                ET.register_namespace('', 'http://www.w3.org/2000/svg')

                for elem in root.iter():
                    if elem.tag.endswith('}path') or elem.tag == 'path':
                        elem_class = elem.get('class', '')
                        elem_id = elem.get('id', '')

                        has_colored_fill = elem.get('fill', '').lower() not in ('', 'none')
                        has_stroke = elem.get('stroke', '').lower() not in ('', 'none')

                        if has_colored_fill and has_stroke:
                            # Element has both fill and stroke (e.g. main cursor path):
                            # use independent fill-opacity/stroke-opacity so fill can
                            # be made transparent while keeping the outline visible.
                            if 'watch' in elem_class or 'watch' in elem_id:
                                f_op, s_op = preset.watch_opacity, preset.watch_opacity
                            else:
                                f_op, s_op = preset.base_opacity, preset.outline_opacity
                            if not elem.get('fill-opacity'):
                                elem.set('fill-opacity', str(f_op))
                            if not elem.get('stroke-opacity'):
                                elem.set('stroke-opacity', str(s_op))
                        else:
                            # Single-role element: use unified opacity
                            if 'outline' in elem_class or 'outline' in elem_id or has_stroke:
                                opacity = preset.outline_opacity
                            elif 'watch' in elem_class or 'watch' in elem_id:
                                opacity = preset.watch_opacity
                            else:
                                opacity = preset.base_opacity
                            if not elem.get('opacity'):
                                elem.set('opacity', str(opacity))

                    elif elem.tag.endswith('}g') or elem.tag == 'g':
                        elem_class = elem.get('class', '')
                        if 'outline' in elem_class:
                            elem.set('opacity', str(preset.outline_opacity))
                        elif 'watch' in elem_class:
                            elem.set('opacity', str(preset.watch_opacity))
                        elif 'base' in elem_class or 'fill' in elem_class:
                            elem.set('opacity', str(preset.base_opacity))

                tree.write(svg_file, encoding='utf-8', xml_declaration=True)
            except Exception:
                pass  # File was already copied intact by copytree

        return temp_dir
    except Exception:
        if temp_dir.exists():
            shutil.rmtree(temp_dir)
        return svg_dir

def ensure_contrast(base: str, outline: str, min_ratio: float = 3.0) -> str:
    """Adjust outline color to ensure minimum contrast with base."""
    if contrast_ratio(base, outline) >= min_ratio:
        return outline

    # If base is light, make outline darker; otherwise lighter
    if is_light_color(base):
        adjusted = outline
        for _ in range(10):
            adjusted = darken_color(adjusted, 0.15)
            if contrast_ratio(base, adjusted) >= min_ratio:
                return adjusted
        return "#000000"
    else:
        adjusted = outline
        for _ in range(10):
            adjusted = lighten_color(adjusted, 0.15)
            if contrast_ratio(base, adjusted) >= min_ratio:
                return adjusted
        return "#ffffff"

def validate_hex_color(color: str) -> str:
    """Validate and normalize hex color to #RRGGBB format.

    Args:
        color: Hex color string (#RGB or #RRGGBB)

    Returns:
        Normalized #RRGGBB format

    Raises:
        ValueError: If color format is invalid
    """
    color = color.strip()

    # Match #RGB or #RRGGBB
    match = re.match(r'^#?([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$', color)
    if not match:
        raise ValueError(f"Invalid hex color: '{color}'. Use format #RGB or #RRGGBB (e.g., #ff00ff)")

    hex_part = match.group(1)

    # Expand #RGB to #RRGGBB
    if len(hex_part) == 3:
        hex_part = ''.join(c * 2 for c in hex_part)

    return f"#{hex_part.lower()}"

def generate_random_vibrant_color() -> str:
    """Generate a random vibrant, saturated color suitable for a cursor.

    Uses HSV color space to ensure the color is always visually striking:
    - Random hue (0-360)
    - High saturation (0.7-1.0)
    - Medium-high value (0.6-0.9)

    Returns:
        Hex color string in #RRGGBB format
    """
    hue = random.random()  # 0-1
    saturation = 0.7 + random.random() * 0.3  # 0.7-1.0
    value = 0.6 + random.random() * 0.3  # 0.6-0.9

    r, g, b = colorsys.hsv_to_rgb(hue, saturation, value)
    return rgb_to_hex(int(r * 255), int(g * 255), int(b * 255))

def open_color_picker(initial_color: str = "#ff00ff", initial_transparency_preset: str = "auto") -> Optional[Dict]:
    """Open a glassmorphic color picker with cursor preview, presets, and transparency options.

    Features a midnight glass aesthetic with floating frosted panels,
    electric cyan accents, persistent preset storage, and transparency preset selector.

    Args:
        initial_color: Starting color in hex format
        initial_transparency_preset: Starting transparency preset (auto, glass, shadow, neon, classic)

    Returns:
        Dictionary with keys:
          - "color": Selected color in hex format
          - "preset": Selected transparency preset name
        Returns None if cancelled
    """
    try:
        import tkinter as tk
    except ImportError:
        raise RuntimeError("tkinter is required for --picker. Install tk package (sudo pacman -S tk).")

    try:
        initial_color = validate_hex_color(initial_color)
    except ValueError:
        initial_color = "#ff00ff"

    # ══════════════════════════════════════════════════════════════════════════
    # MIDNIGHT GLASS PALETTE - Deep void with luminescent frosted panels
    # ══════════════════════════════════════════════════════════════════════════

    VOID           = "#030508"      # Deepest background - the void
    GLASS          = "#0a1220"      # Frosted glass panel fill
    GLASS_INNER    = "#0e1a2d"      # Inner glass highlight
    GLASS_EDGE     = "#1a3555"      # Glass border - soft glow
    GLASS_BRIGHT   = "#2a5580"      # Bright edge highlight
    GLASS_SHADOW   = "#020406"      # Deep shadow beneath panels

    INPUT_BG       = "#081018"      # Input field background
    INPUT_BORDER   = "#1a3050"      # Input field border

    FG             = "#e4eaf4"      # Primary text - crisp white
    FG_DIM         = "#5a7090"      # Muted text
    FG_FAINT       = "#2a4060"      # Very subtle text

    ACCENT         = "#00d4ff"      # Electric cyan - primary accent
    ACCENT_DIM     = "#007a99"      # Dimmed cyan
    ACCENT_GLOW    = "#00a8cc"      # Cyan glow

    VIOLET         = "#a855f7"      # Secondary accent - violet
    VIOLET_DIM     = "#7c3aed"      # Dimmed violet

    SUCCESS        = "#10b981"      # Apply button - emerald
    SUCCESS_HOVER  = "#059669"      # Apply hover
    DANGER         = "#ef4444"      # Delete/warning

    # ══════════════════════════════════════════════════════════════════════════
    # PRESET STORAGE - Persistent color presets in JSON
    # ══════════════════════════════════════════════════════════════════════════

    PRESETS_PATH = Path.home() / ".config" / "bibata-omarchy-sync" / "presets.json"

    DEFAULT_PRESETS = [
        "#00d4ff", "#a855f7", "#f472b6", "#fb923c",
        "#10b981", "#facc15", "#ef4444", "#3b82f6",
        "#8b5cf6", "#ec4899", "#14b8a6", "#f59e0b",
        "#06b6d4", "#6366f1", "#84cc16", "#f97316",
    ]

    def load_presets() -> list:
        """Load presets from disk or return defaults."""
        if PRESETS_PATH.exists():
            try:
                with open(PRESETS_PATH, 'r') as f:
                    data = json.load(f)
                    if isinstance(data, list) and len(data) > 0:
                        return [c for c in data if isinstance(c, str)]
            except (json.JSONDecodeError, IOError):
                pass
        return DEFAULT_PRESETS.copy()

    def save_presets(presets: list):
        """Persist presets to disk."""
        try:
            PRESETS_PATH.parent.mkdir(parents=True, exist_ok=True)
            with open(PRESETS_PATH, 'w') as f:
                json.dump(presets, f, indent=2)
        except IOError:
            pass

    # ══════════════════════════════════════════════════════════════════════════
    # APPLICATION STATE
    # ══════════════════════════════════════════════════════════════════════════

    root = tk.Tk()
    root.title("")  # Minimal - no title for cleaner look
    root.configure(bg=VOID)
    root.resizable(False, False)

    # Remove window decorations for pure glassmorphic look (optional)
    # root.overrideredirect(True)

    selected_color = [None]
    selected_outline = [None]  # Track selected outline color for return
    selected_preset = [initial_transparency_preset]  # Track transparency preset selection
    current_hsv = list(colorsys.rgb_to_hsv(*[x/255 for x in hex_to_rgb(initial_color)]))
    outline_hex = [None]  # None = auto-computed, hex string = custom override
    user_presets = load_presets()
    _updating = [False]
    preset_widgets = []  # Track preset swatches for rebuilding
    transparency_buttons = []  # Track transparency preset buttons

    def hsv_to_hex_local(h, s, v):
        r, g, b = colorsys.hsv_to_rgb(h, s, v)
        return rgb_to_hex(int(r * 255), int(g * 255), int(b * 255))

    def current_color():
        return hsv_to_hex_local(current_hsv[0], current_hsv[1], current_hsv[2])

    # ══════════════════════════════════════════════════════════════════════════
    # GLASSMORPHIC DRAWING UTILITIES
    # ══════════════════════════════════════════════════════════════════════════

    def draw_glass_panel(canvas, x, y, w, h, glow_color=None):
        """Draw a frosted glass panel with inner glow and edge highlights."""
        # Outer shadow (depth)
        canvas.create_rectangle(x+2, y+2, x+w+2, y+h+2, fill=GLASS_SHADOW, outline="")

        # Main glass body
        canvas.create_rectangle(x, y, x+w, y+h, fill=GLASS, outline="")

        # Inner glow gradient (top-left to bottom-right)
        for i in range(8):
            alpha = (8 - i) / 8.0
            glow = glow_color if glow_color else GLASS_INNER
            r1, g1, b1 = hex_to_rgb(GLASS)
            r2, g2, b2 = hex_to_rgb(glow)
            r = int(r1 + (r2 - r1) * alpha * 0.3)
            g = int(g1 + (g2 - g1) * alpha * 0.3)
            b = int(b1 + (b2 - b1) * alpha * 0.3)
            canvas.create_rectangle(x+i, y+i, x+w-i, y+h-i,
                                   fill=rgb_to_hex(r, g, b), outline="")

        # Top edge highlight (light refraction)
        canvas.create_line(x+1, y+1, x+w-1, y+1, fill=GLASS_BRIGHT, width=1)

        # Left edge subtle highlight
        canvas.create_line(x+1, y+1, x+1, y+h-1, fill=GLASS_EDGE, width=1)

        # Border glow
        canvas.create_rectangle(x, y, x+w, y+h, fill="", outline=GLASS_EDGE, width=1)

    # ══════════════════════════════════════════════════════════════════════════
    # CURSOR PREVIEW - Glowing Bibata cursor visualization
    # ══════════════════════════════════════════════════════════════════════════

    PREVIEW_W, PREVIEW_H = 200, 180

    def draw_cursor_preview(fill_color, outline_color, outline_only=False):
        """Draw the Bibata cursor with ambient glow effect."""
        preview_canvas.delete("all")

        # Draw glass panel background
        glow_source = outline_color if outline_only else fill_color
        draw_glass_panel(preview_canvas, 0, 0, PREVIEW_W, PREVIEW_H, glow_source)

        cx, cy = PREVIEW_W // 2, PREVIEW_H // 2 + 8
        r_bg, g_bg, b_bg = hex_to_rgb(GLASS)
        r_fc, g_fc, b_fc = hex_to_rgb(glow_source)

        # Ambient glow - more intense, colored by visible cursor color
        for i in range(50, 0, -1):
            t = i / 50.0
            blend = t * t * 0.15
            rr = max(0, min(255, int(r_bg + (r_fc - r_bg) * blend)))
            gg = max(0, min(255, int(g_bg + (g_fc - g_bg) * blend)))
            bb = max(0, min(255, int(b_bg + (b_fc - b_bg) * blend)))
            c = rgb_to_hex(rr, gg, bb)
            rad = int(i * 2.0)
            preview_canvas.create_oval(cx - rad, cy - rad, cx + rad, cy + rad,
                                       fill=c, outline="")

        # Bibata Modern pointer vertices
        bibata_pts = [
            (60, 24), (46, 54), (46, 200), (56, 224), (72, 232),
            (93, 222), (104, 210), (132, 187), (168, 181), (185, 181),
            (199, 179), (211, 156), (201, 134), (92, 36), (76, 26),
        ]

        scale = 0.65
        min_x = min(p[0] for p in bibata_pts)
        max_x = max(p[0] for p in bibata_pts)
        min_y = min(p[1] for p in bibata_pts)
        max_y = max(p[1] for p in bibata_pts)
        shape_w = (max_x - min_x) * scale
        shape_h = (max_y - min_y) * scale
        off_x = (PREVIEW_W - shape_w) / 2 - min_x * scale
        off_y = (PREVIEW_H - shape_h) / 2 - min_y * scale

        def transform(pts):
            flat = []
            for x, y in pts:
                flat.extend([x * scale + off_x, y * scale + off_y])
            return flat

        points = transform(bibata_pts)

        # Drop shadow
        shadow_pts = [p + 3 for p in points]
        preview_canvas.create_polygon(shadow_pts, fill=GLASS_SHADOW, outline="", smooth=True)

        if outline_only:
            # Outline-only mode: hollow cursor with just the border stroke
            preview_canvas.create_polygon(points, fill="",
                                          outline=outline_color, width=8,
                                          smooth=True, joinstyle=tk.ROUND)
        else:
            # Outline layer
            preview_canvas.create_polygon(points, fill=outline_color,
                                          outline=outline_color, width=10,
                                          smooth=True, joinstyle=tk.ROUND)

            # Fill layer
            preview_canvas.create_polygon(points, fill=fill_color,
                                          outline=fill_color, width=2,
                                          smooth=True, joinstyle=tk.ROUND)


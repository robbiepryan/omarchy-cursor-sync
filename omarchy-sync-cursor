@dataclass
class TransparencyPreset:
    """Transparency preset definition."""
    name: str  # "glass", "shadow", "neon", "classic"
    base_opacity: float  # 0.0-1.0
    outline_opacity: float  # 0.0-1.0
    watch_opacity: float  # 0.0-1.0

@dataclass
class Config:
    """Configuration for cursor sync."""
    bibata_source_dir: Path
    cache_dir: Path
    icons_dir: Path
    themes_dir: Path
    cursor_size: int
    cursor_style: str
    color_source: str
    cursor_conf: Path
    base_color_source: str
    base_color_fallback: str
    outline_color_source: str
    watch_color_source: str
    venv_path: Path
    # Color overrides (empty string means use auto)
    override_base_color: str
    override_outline_color: str
    override_watch_color: str
    # Transparency settings
    transparency_preset: str  # "auto", "glass", "shadow", "neon", "classic"

def load_config() -> Config:
    """Load configuration from config.toml or use defaults."""
    config_path = Path.home() / ".config" / "bibata-omarchy-sync" / "config.toml"

    # Defaults
    defaults = {
        "bibata_source_dir": Path.home() / "src" / "Bibata_Cursor",
        "cache_dir": Path.home() / ".local" / "share" / "bibata-omarchy-cache",
        "icons_dir": Path.home() / ".local" / "share" / "icons",
        "themes_dir": Path.home() / ".config" / "omarchy" / "themes",
        "cursor_size": 24,
        "cursor_style": "modern",
        "color_source": "alacritty.toml",
        "cursor_conf": Path.home() / ".config" / "hypr" / "cursor-auto.conf",
        "base_color_source": "cursor",
        "base_color_fallback": "magenta",
        "outline_color_source": "background",
        "watch_color_source": "background",
        "venv_path": Path.home() / ".local" / "bibata-venv",
        "override_base_color": "",
        "override_outline_color": "",
        "override_watch_color": "",
        "transparency_preset": "auto",
    }

    if config_path.exists() and HAS_TOML:
        try:
            data = toml.load(config_path)
            paths = data.get("paths", {})
            cursor = data.get("cursor", {})
            hyprland = data.get("hyprland", {})
            color_mapping = data.get("color_mapping", {})
            color_override = data.get("color_override", {})
            transparency = data.get("transparency", {})

            def expand_path(p: str) -> Path:
                return Path(os.path.expanduser(p))

            return Config(
                bibata_source_dir=expand_path(paths.get("bibata_source_dir", str(defaults["bibata_source_dir"]))),
                cache_dir=expand_path(paths.get("cache_dir", str(defaults["cache_dir"]))),
                icons_dir=expand_path(paths.get("icons_dir", str(defaults["icons_dir"]))),
                themes_dir=expand_path(paths.get("themes_dir", str(defaults["themes_dir"]))),
                cursor_size=cursor.get("size", defaults["cursor_size"]),
                cursor_style=cursor.get("style", defaults["cursor_style"]),
                color_source=cursor.get("color_source", defaults["color_source"]),
                cursor_conf=expand_path(hyprland.get("cursor_conf", str(defaults["cursor_conf"]))),
                base_color_source=color_mapping.get("base_color_source", defaults["base_color_source"]),
                base_color_fallback=color_mapping.get("base_color_fallback", defaults["base_color_fallback"]),
                outline_color_source=color_mapping.get("outline_color_source", defaults["outline_color_source"]),
                watch_color_source=color_mapping.get("watch_color_source", defaults["watch_color_source"]),
                venv_path=defaults["venv_path"],

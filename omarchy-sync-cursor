#!/usr/bin/env python3
"""
Omarchy Cursor Sync - Build and apply Bibata cursors matching theme colors.

This script:
1. Reads colors from the current Omarchy theme's alacritty.toml
2. Computes aesthetically pleasing cursor colors from the palette
3. Builds a custom Bibata cursor theme using cbmp + ctgen
4. Installs and applies the cursor across Hyprland, XCursor, and GTK

Usage:
    omarchy-sync-cursor <theme_name>
    omarchy-sync-cursor --current              # Uses currently active theme
    omarchy-sync-cursor <theme> --base-color "#ff00ff"   # Override base color
    omarchy-sync-cursor --color-only --base-color "#ff00ff"  # No theme needed
    omarchy-sync-cursor --random               # Random vibrant color
    omarchy-sync-cursor --picker               # GUI color picker
"""

